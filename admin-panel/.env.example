# Copy to `.env.local` for local development.

NEXTAUTH_URL=http://localhost:3001
NEXTAUTH_SECRET=change-me-min-32-chars-for-nextauth-secret-only-dev

# Browser: admin API base. Either form works — `/admin` is appended if missing.
# NEXT_PUBLIC_API_URL=http://localhost:3000/admin
NEXT_PUBLIC_API_URL=http://localhost:3000

# Server-side login from NextAuth Credentials (same host as Nest, no /admin suffix).
API_URL_INTERNAL=http://localhost:3000
