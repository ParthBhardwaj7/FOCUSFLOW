# Copy to .env and fill values. Never commit .env.

# App
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# Database (Prisma) — local: start Postgres with `docker compose up -d`
# Must match POSTGRES_PASSWORD in docker-compose.yml
DATABASE_URL=postgresql://postgres:mypassword123@localhost:5432/focusflow?schema=public
# Optional: only if your host requires a shadow DB for migrate (e.g. some cloud providers)
# SHADOW_DATABASE_URL=

# Auth — access secret must be **32+ characters** or the app will not boot.
# (Optional legacy key — refresh tokens are stored hashed in DB, not JWT-signed.)
# JWT_REFRESH_SECRET=
JWT_ACCESS_SECRET=change-me-min-32-chars-for-development-only-okX
# Dev-friendly long expiry (use shorter values in production, e.g. 15m / 7d).
JWT_ACCESS_EXPIRES_IN=365d
JWT_REFRESH_EXPIRES_IN=36500d
# Comma-separated Google OAuth client IDs allowed as ID token audience.
# Include at least your Firebase Web client ID used by the mobile app.
# GOOGLE_AUTH_CLIENT_IDS=1234567890-abc123def456.apps.googleusercontent.com

# CORS — comma-separated origins; no spaces. Use exact dev server URLs.
# Include the admin panel dev origin (Next.js often runs on :3001 while API is :3000).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:3001

# Optional: separate signing secret for admin JWT (falls back to JWT_ACCESS_SECRET).
# ADMIN_JWT_ACCESS_SECRET=change-me-min-32-chars-for-development-only-okY
# ADMIN_JWT_ACCESS_EXPIRES_IN=15m

# Optional: absolute public URL prefix for uploaded sound files served from this API host.
# SOUND_PUBLIC_BASE_URL=http://localhost:3000

# Optional: Firebase Cloud Messaging legacy server key (admin panel → send push).
# Same value can be set as CM_SERVER_KEY if you prefer that name.
# FCM_SERVER_KEY=
# CM_SERVER_KEY=

# Optional: internal API URL for NextAuth server-side login (defaults from NEXT_PUBLIC_API_URL).
# API_URL_INTERNAL=http://localhost:3000

# Cookies (refresh token strategy later)
COOKIE_DOMAIN=
COOKIE_SECURE=false

# Rate limiting (global defaults)
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Optional observability
# SENTRY_DSN=

# AI (optional — omit to disable chat until configured)
# LLM_PROVIDER=openrouter
# LLM_API_KEY=
# LLM_MODEL=openai/gpt-4o-mini
# Optional override (OpenRouter default: https://openrouter.ai/api/v1)
# LLM_BASE_URL=
#
# Groq: LLM_PROVIDER=groq LLM_BASE_URL=https://api.groq.com/openai/v1
# Gemini: LLM_PROVIDER=gemini LLM_MODEL=gemini-1.5-flash
