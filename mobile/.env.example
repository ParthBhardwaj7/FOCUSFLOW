# Copy to `.env` in this folder (gitignored).
#
# Physical Android phone (same Wi‑Fi as your PC) — use your PC’s LAN IPv4 (ipconfig):
#   API_BASE_URL=http://192.168.1.10:3000
# (Backend must accept LAN connections, e.g. listen on 0.0.0.0:3000, not only localhost.)
#
# Android emulator → host machine (default below if you copy this file as `.env`):
API_BASE_URL=http://10.0.2.2:3000
#
# Release: use HTTPS (e.g. https://api.example.com); release Android builds set
# usesCleartextTraffic=false so plain http:// API URLs will fail to connect.

# Required for Google Sign-In ID token on Android.
# Firebase Console -> Project settings -> General -> Your apps -> Web app -> Web client ID
# Example: GOOGLE_WEB_CLIENT_ID=1234567890-abc123def456.apps.googleusercontent.com
# GOOGLE_WEB_CLIENT_ID=
